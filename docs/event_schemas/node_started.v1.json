{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lens.tsmc/event_schemas/node_started.v1.json",
  "title": "NodeStarted",
  "description": "A node (at any granularity level) has begun execution. Phase-0 envelope shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "schema_version",
    "event_id",
    "timestamp",
    "build_id",
    "node_id",
    "level",
    "entity_id"
  ],
  "properties": {
    "event_type": { "const": "NodeStarted" },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "build_id": { "type": "string" },
    "parent_event_id": {
      "oneOf": [
        { "type": "string", "format": "uuid" },
        { "type": "null" }
      ]
    },
    "node_id": { "type": "string" },
    "level": { "enum": ["build", "library", "flow", "pvt", "cell"] },
    "entity_id": { "type": "string" },
    "input_hash": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "resource_request": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        { "type": "null" }
      ]
    }
  }
}
