{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lens.tsmc/event_schemas/flow_started.v1.json",
  "title": "FlowStarted",
  "description": "A flow has begun execution. level is locked to 'flow'. library and owner are nullable per decision Q2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "schema_version",
    "event_id",
    "timestamp",
    "build_id",
    "level",
    "entity_id"
  ],
  "properties": {
    "event_type": { "const": "FlowStarted" },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "build_id": { "type": "string" },
    "parent_event_id": {
      "oneOf": [
        { "type": "string", "format": "uuid" },
        { "type": "null" }
      ]
    },
    "level": { "const": "flow" },
    "entity_id": { "type": "string" },
    "library": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "owner": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    }
  }
}
