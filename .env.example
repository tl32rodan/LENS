# LENS — environment variables (copy to `.env` for local dev)
# All variables are optional; defaults are documented in src/lens/config.py.

# ---------------------------------------------------------------------------
# Adapter switches (DP-8 — Replaceable Adapters).
#   memory   — pure in-process; no external services. Demos / CI.
#   kafka    — production: real broker via aiokafka.
#   postgres — production: real DB via asyncpg + SQLAlchemy.
# ---------------------------------------------------------------------------
LENS_BUS=kafka
LENS_PROJECTION_STORE=postgres

# ---------------------------------------------------------------------------
# Kafka (LENS_BUS=kafka). The platform does NOT manage broker lifecycle —
# point this at whatever Kafka the deployment env provides.
# ---------------------------------------------------------------------------
LENS_KAFKA_BOOTSTRAP_SERVERS=["broker-a:9092", "broker-b:9092"]
LENS_KAFKA_TOPIC_EVENTS=build.events
LENS_KAFKA_TOPIC_DLQ=build.events.dlq

# Producer's local-buffer file (used when broker is unavailable, drained on
# recovery). Phase-0 deferred: no DLQ topic; failures land here only.
LENS_PRODUCER_LOCAL_BUFFER_PATH=/var/lib/lens/producer-buffer.ndjson

# ---------------------------------------------------------------------------
# Postgres (LENS_PROJECTION_STORE=postgres). Driver MUST be asyncpg —
# `lens.config.Settings` validates this at startup.
# ---------------------------------------------------------------------------
LENS_PG_DSN=postgresql+asyncpg://lens:lens@db.internal:5432/lens

# ---------------------------------------------------------------------------
# API server (`uvicorn lens.api.asgi:app`).
# ---------------------------------------------------------------------------
LENS_API_HOST=0.0.0.0
LENS_API_PORT=8000

# ---------------------------------------------------------------------------
# Observer (L0). Phase-0 reads AP's CSV dashboard at OBSERVER_CSV_PATH on
# OBSERVER_POLL_INTERVAL_SEC ticks. The CSV column schema is the assumed
# default documented in src/lens/observer/ap_bridge.py — swap the
# `CSVStatusSource` parser if AP's real format differs.
# ---------------------------------------------------------------------------
LENS_OBSERVER_CSV_PATH=/data/ap/dashboard.csv
LENS_OBSERVER_POLL_INTERVAL_SEC=5.0
LENS_OBSERVER_BUILD_ID=default-build

# ---------------------------------------------------------------------------
# Misc.
# ---------------------------------------------------------------------------
LENS_LOG_LEVEL=INFO
